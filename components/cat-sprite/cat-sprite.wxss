/* components/cat-sprite/cat-sprite.wxss */
.cat-sprite {
  display: flex;
  align-items: center;
  justify-content: center;
  image-rendering: pixelated;
  flex-shrink: 0;
}

.default-cat {
  line-height: 1;
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.2));
}

/* 浮动动画（继承 app.wxss 的 anim-float） */
.cat-sprite.anim-float {
  animation: float 2s ease-in-out infinite;
}

/* 进食时小幅抖动 */
@keyframes eat-shake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-8deg); }
  75% { transform: rotate(8deg); }
}

.cat-sprite.eating {
  animation: eat-shake 0.5s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6px); }
}
