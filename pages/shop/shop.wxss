/* pages/shop/shop.wxss */
.shop-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

.shop-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx 16rpx;
  background: linear-gradient(135deg, #FFF3E0, #FFE0B2);
  border-bottom: 4rpx solid var(--color-bg-warm);
}

.shop-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-dark);
}

.currency-bar {
  display: flex;
  gap: 16rpx;
}

.currency-item {
  display: flex;
  align-items: center;
  background: rgba(255,255,255,0.8);
  border-radius: 16rpx;
  padding: 8rpx 16rpx;
  border: 3rpx solid var(--color-bg-warm);
}

.currency-item.gold {
  border-color: #F5C842;
}

.currency-num {
  font-size: 26rpx;
  font-weight: 700;
  color: var(--color-text-dark);
  font-family: 'Courier New', monospace;
}

.shop-list {
  flex: 1;
  padding: 10rpx 24rpx 0;
}

.shop-item-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 16rpx;
  background: white;
  border-radius: 16rpx;
  border: 3rpx solid var(--color-bg-warm);
  margin-bottom: 16rpx;
  box-shadow: 3rpx 3rpx 0 var(--color-bg-warm);
}

.shop-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: #FFF8F0;
  border-radius: 12rpx;
  border: 2rpx solid #F0DEC0;
}

.shop-icon {
  width: 56rpx;
  height: 56rpx;
  image-rendering: pixelated;
}

.shop-item-info {
  flex: 1;
  min-width: 0;
}

.item-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.shop-item-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-dark);
}

.owned-badge {
  font-size: 18rpx;
  background: #E8F5E9;
  color: #388E3C;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.shop-item-desc {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-mid);
  line-height: 1.4;
  margin-bottom: 8rpx;
  /* 超出省略 */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.attract-bar {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.attract-label {
  font-size: 18rpx;
  color: #9E9E9E;
}

.attract-dots {
  display: flex;
  gap: 4rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 2rpx;
  background: #E0E0E0;
  border: 1rpx solid #BDBDBD;
}

.dot.filled {
  background: var(--color-primary);
  border-color: var(--color-primary-dark);
}

.shop-buy-area {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}

.price-tag {
  font-size: 24rpx;
  color: var(--color-primary-dark);
  font-weight: 700;
}

.price-num {
  font-family: 'Courier New', monospace;
}

/* 确认弹窗 */
.confirm-modal {
  max-width: 560rpx;
}

.confirm-item-preview {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 20rpx;
  background: #FFF8F0;
  border-radius: 12rpx;
  border: 3rpx solid var(--color-bg-warm);
  margin-bottom: 20rpx;
}

.confirm-item-detail {
  flex: 1;
}

.confirm-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-dark);
  margin-bottom: 8rpx;
}

.confirm-price {
  display: block;
  font-size: 26rpx;
  color: var(--color-primary-dark);
  font-weight: 600;
}

.confirm-balance {
  font-size: 26rpx;
  color: var(--color-text-mid);
  text-align: center;
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: white;
  border-radius: 10rpx;
  border: 2rpx solid var(--color-bg-warm);
}

.balance-after {
  color: var(--color-danger);
  font-weight: 700;
}

.confirm-btns {
  display: flex;
  gap: 20rpx;
}
