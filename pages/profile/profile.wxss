/* pages/profile/profile.wxss */
.profile-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

/* 头像区 */
.profile-header {
  display: flex;
  align-items: center;
  gap: 30rpx;
  padding: 40rpx 30rpx 30rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE082 100%);
  border-bottom: 4rpx solid var(--color-bg-warm);
}

.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  border: 6rpx solid var(--color-primary);
  box-shadow: 0 4rpx 16rpx rgba(232,147,90,0.3);
}

.avatar-placeholder {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  border: 6rpx solid var(--color-primary);
}

.avatar-deco {
  position: absolute;
  bottom: -6rpx;
  right: -6rpx;
  width: 30rpx;
  height: 30rpx;
  background: var(--color-gold);
  border-radius: 50%;
  border: 3rpx solid white;
}

.user-info {
  flex: 1;
}

.nickname {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-dark);
  margin-bottom: 8rpx;
}

.play-days {
  font-size: 24rpx;
  color: var(--color-text-mid);
}

/* 货币展示 */
.currency-banner {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 30rpx;
  background: white;
  border-bottom: 4rpx solid var(--color-bg-warm);
}

.currency-block {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.c-icon {
  font-size: 36rpx;
}

.c-num {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-text-dark);
  font-family: 'Courier New', monospace;
}

.c-label {
  font-size: 22rpx;
  color: var(--color-text-mid);
}

.c-divider {
  width: 2rpx;
  height: 80rpx;
  background: var(--color-bg-warm);
}

/* 分区标题 */
.section-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-dark);
  padding: 24rpx 30rpx 12rpx;
  letter-spacing: 2rpx;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 0 24rpx;
}

.stat-card {
  background: white;
  border-radius: 16rpx;
  border: 4rpx solid var(--color-bg-warm);
  box-shadow: 3rpx 3rpx 0 var(--color-bg-warm);
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-big {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--color-primary);
  font-family: 'Courier New', monospace;
}

.stat-small {
  font-size: 22rpx;
  color: var(--color-text-mid);
}

/* 成就列表 */
.achievements-list {
  padding: 0 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ach-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  border: 4rpx solid;
  transition: all 0.2s;
}

.ach-item.unlocked {
  background: linear-gradient(135deg, #FFFDE7, #FFF9C4);
  border-color: var(--color-gold);
  box-shadow: 3rpx 3rpx 0 #C8A000;
}

.ach-item.locked {
  background: #F5F5F5;
  border-color: #E0E0E0;
  opacity: 0.7;
}

.ach-icon {
  font-size: 44rpx;
  flex-shrink: 0;
}

.ach-info {
  flex: 1;
}

.ach-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-dark);
  margin-bottom: 4rpx;
}

.ach-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-mid);
}

.ach-badge {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-success);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  flex-shrink: 0;
}
