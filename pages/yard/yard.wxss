/* pages/yard/yard.wxss */

.yard-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
  position: relative;
  overflow: hidden;
}

/* ===== HUD 顶部栏 ===== */
.hud-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: rgba(253, 246, 227, 0.95);
  backdrop-filter: blur(4px);
  border-bottom: 4rpx solid var(--color-bg-warm);
  z-index: 50;
  flex-shrink: 0;
}

.refresh-timer {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255,255,255,0.8);
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
  border: 3rpx solid #E8D5B0;
  min-width: 80rpx;
  cursor: pointer;
}

.timer-icon {
  font-size: 28rpx;
  line-height: 1;
}

.timer-num {
  font-size: 20rpx;
  color: var(--color-text-mid);
  font-family: 'Courier New', monospace;
}

.refresh-timer.spinning .timer-icon {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.scene-switch {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255,255,255,0.8);
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
  border: 3rpx solid #E8D5B0;
  cursor: pointer;
  transition: all 0.2s;
}

.scene-switch:active {
  transform: scale(0.94);
  background: #F0E8D8;
}

.scene-icon {
  font-size: 30rpx;
  line-height: 1;
}

.scene-label {
  font-size: 20rpx;
  color: var(--color-text-mid);
  font-weight: 600;
}

/* ===== 场景背景 ===== */
.scene-bg {
  flex: 1;
  position: relative;
  overflow: hidden;
}

/* 后院背景 */
.yard-bg {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.sky {
  height: 35%;
  background: linear-gradient(180deg, #87CEEB 0%, #B0E0E6 100%);
  position: relative;
  overflow: hidden;
}

.cloud {
  position: absolute;
  font-size: 48rpx;
  opacity: 0.8;
  animation: cloud-drift 20s linear infinite;
}

.cloud1 { top: 20rpx; left: -60rpx; animation-duration: 25s; }
.cloud2 { top: 50rpx; left: 30%; animation-duration: 18s; animation-delay: -8s; }

@keyframes cloud-drift {
  from { transform: translateX(0); }
  to { transform: translateX(800rpx); }
}

.sun {
  position: absolute;
  top: 16rpx;
  right: 30rpx;
  font-size: 56rpx;
  animation: sun-glow 3s ease-in-out infinite;
}

@keyframes sun-glow {
  0%, 100% { text-shadow: 0 0 10rpx rgba(255, 213, 0, 0.4); }
  50% { text-shadow: 0 0 30rpx rgba(255, 213, 0, 0.9); }
}

.grass-area {
  flex: 1;
  background: linear-gradient(180deg, #81C784 0%, #66BB6A 40%, #C8E6C9 100%);
  padding: 20rpx 16rpx 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.fence {
  height: 48rpx;
  background: repeating-linear-gradient(
    90deg,
    #8D6E63 0px, #8D6E63 20rpx,
    transparent 20rpx, transparent 40rpx
  );
  border-top: 8rpx solid #6D4C41;
}

/* 室内背景 */
.indoor-bg {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.wall {
  height: 40%;
  background: linear-gradient(180deg, #FFECB3 0%, #FFE082 100%);
  position: relative;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 40rpx;
}

.wall-decoration {
  font-size: 60rpx;
  opacity: 0.7;
}

.floor-area {
  flex: 1;
  background: linear-gradient(180deg, #D7CCC8 0%, #BCAAA4 100%);
  padding: 20rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

/* 木地板纹理 */
.floor-area::before {
  content: '';
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent 0px, transparent 40rpx,
    rgba(0,0,0,0.04) 40rpx, rgba(0,0,0,0.04) 42rpx
  );
}

/* ===== 槽位网格 ===== */
.slots-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24rpx;
  padding: 16rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 20rpx;
  border: 3rpx solid rgba(255,255,255,0.5);
  backdrop-filter: blur(2px);
  position: relative;
  z-index: 1;
}

/* ===== 猫咪叠加层 ===== */
.cats-layer {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 20;
}

.cat-on-slot {
  position: absolute;
  pointer-events: auto;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 16rpx 24rpx;
  background: rgba(253, 246, 227, 0.97);
  border-top: 4rpx solid var(--color-bg-warm);
  z-index: 50;
  flex-shrink: 0;
}

.collect-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  border: 4rpx solid;
  font-weight: 700;
  font-size: 26rpx;
  transition: all 0.2s;
}

.collect-btn.active {
  background: linear-gradient(135deg, #E8935A, #D4714A);
  border-color: #C86030;
  color: white;
  box-shadow: 0 4rpx 0 #C86030, 0 4rpx 20rpx rgba(232,147,90,0.4);
}

.collect-btn.inactive {
  background: #F5F5F5;
  border-color: #E0E0E0;
  color: #BDBDBD;
}

.collect-btn:active {
  transform: translateY(2rpx);
  box-shadow: none !important;
}

.bag-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 110rpx;
  height: 90rpx;
  background: white;
  border-radius: 16rpx;
  border: 4rpx solid var(--color-bg-warm);
  box-shadow: 0 4rpx 0 var(--color-bg-warm);
  transition: all 0.15s;
}

.bag-btn:active {
  transform: translateY(2rpx);
  box-shadow: none;
}

.btn-icon {
  font-size: 36rpx;
  line-height: 1.2;
}

.btn-label {
  font-size: 20rpx;
  color: var(--color-text-mid);
  font-weight: 600;
}

/* ===== 背包面板 ===== */
.panel-mask {
  position: fixed;
  inset: 0;
  background: rgba(62,39,35,0.5);
  z-index: 80;
  display: flex;
  align-items: flex-end;
}

.bag-panel {
  width: 100%;
  max-height: 70vh;
  background: var(--color-bg);
  border-radius: 30rpx 30rpx 0 0;
  border-top: 6rpx solid var(--color-bg-warm);
  display: flex;
  flex-direction: column;
}

.panel-header {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx 16rpx;
  border-bottom: 3rpx solid var(--color-bg-warm);
  flex-shrink: 0;
}

.panel-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-dark);
  flex: 1;
}

.slot-hint {
  font-size: 24rpx;
  color: var(--color-primary);
  margin-right: 20rpx;
}

.close-btn {
  font-size: 32rpx;
  color: var(--color-text-mid);
  padding: 4rpx 8rpx;
}

.bag-list {
  flex: 1;
  padding: 16rpx 24rpx;
}

.bag-item-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  margin-bottom: 12rpx;
  background: white;
  border: 3rpx solid var(--color-bg-warm);
  transition: all 0.15s;
}

.bag-item-row:active {
  background: #FFF3E0;
  transform: scale(0.98);
}

.bag-item-row.disabled {
  opacity: 0.4;
  pointer-events: none;
}

.bag-item-icon {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.bag-item-info {
  flex: 1;
}

.bag-item-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-dark);
}

.bag-item-desc {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-mid);
  margin-top: 4rpx;
  line-height: 1.4;
}

.bag-item-count {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-primary);
  min-width: 50rpx;
  text-align: right;
}

/* ===== 猫咪详情 ===== */
.cat-detail-modal {
  max-width: 560rpx;
  text-align: center;
}

.cat-detail-sprite {
  display: flex;
  justify-content: center;
  margin: 20rpx 0;
}

.cat-detail-info {
  text-align: left;
  background: rgba(255,255,255,0.6);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  border: 3rpx solid var(--color-bg-warm);
}

.info-row {
  display: flex;
  align-items: flex-start;
  padding: 10rpx 0;
  border-bottom: 2rpx solid var(--color-bg-warm);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 24rpx;
  color: var(--color-text-mid);
  width: 80rpx;
  flex-shrink: 0;
  font-weight: 600;
}

.info-value {
  font-size: 26rpx;
  color: var(--color-text-dark);
  flex: 1;
  line-height: 1.5;
}

.info-value.desc {
  font-size: 24rpx;
  color: var(--color-text-mid);
}

.rarity-common { color: #66BB6A; }
.rarity-uncommon { color: #42A5F5; }
.rarity-rare { color: #E8935A; font-weight: 700; }
.rarity-special { color: #F5C842; font-weight: 700; }
